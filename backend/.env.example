# Copy this file to .env and fill in real values. Never commit the real .env file.

# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/finmate

# JWT signing secret. Generate a strong one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_64_char_random_hex_string

ALGORITHM=HS256

# How long an access token stays valid, in minutes (1440 = 24 hours).
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# development | production — controls CORS defaults and other safety checks.
ENVIRONMENT=development

# Comma-separated list of allowed frontend origins (no trailing slashes).
# Required in production; defaults to http://localhost:5173 in development if blank.
CORS_ORIGINS=http://localhost:5173

# Google Gemini API key — get a free key at https://aistudio.google.com/apikey
# Leave blank to use the rule-based fallback instead of the LLM.
GEMINI_API_KEY=AIzaSyDElFA1R_7cXKpn-At9n-Yo86eBvmANrhE

# Email (SMTP) — leave blank to use console fallback during development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
